{
  "name": "@agentlinkdev/agentlink",
  "version": "0.5.0",
  "type": "module",
  "description": "The telephone for AI agents. Discovery, messaging, and coordination between agents via MQTT.",
  "main": "dist/src/index.js",
  "bin": {
    "agentlink": "bin/cli.js"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "examples/",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./dist/bundle.js"
    ]
  },
  "scripts": {
    "build": "tsc && node scripts/bundle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npx tsx test/e2e-two-agent.ts",
    "test:unit": "vitest run --exclude=test/mqtt-roundtrip.test.ts --exclude=test/discovery-mqtt.test.ts --exclude=test/discovery-publish-pattern.test.ts --exclude=test/message-flow.test.ts",
    "prepublishOnly": "npm run build && npm run test:unit"
  },
  "keywords": [
    "openclaw",
    "agent",
    "messaging",
    "mqtt",
    "a2a",
    "plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentlink-dev/agentlink.git"
  },
  "bugs": {
    "url": "https://github.com/agentlink-dev/agentlink/issues"
  },
  "homepage": "https://agent.lk",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bs58": "^5.0.0",
    "hash-wasm": "^4.12.0",
    "js-sdsl": "^4.3.0",
    "lru-cache": "^10.4.3",
    "mqtt": "^5.10.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "uuid": "^11.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "openclaw": "^2026.3.12"
  },
  "overrides": {
    "rollup": "4.28.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.28.1",
    "@rollup/rollup-darwin-x64": "4.28.1",
    "@rollup/rollup-linux-arm64-gnu": "4.28.1",
    "@rollup/rollup-linux-arm64-musl": "4.28.1",
    "@rollup/rollup-linux-x64-gnu": "4.28.1",
    "@rollup/rollup-linux-x64-musl": "4.28.1",
    "@rollup/rollup-win32-arm64-msvc": "4.28.1",
    "@rollup/rollup-win32-x64-msvc": "4.28.1"
  }
}
